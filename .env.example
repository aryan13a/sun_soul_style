# Sun Soul Style — Environment Variables Template
# Copy this file to .env for local development

# 1. Admin Authentication Security
# A strong random secret key (at least 32 characters) used to sign session cookies.
# Generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_session_secret_here

# 2. Vercel Blob Storage Integration
# Required for database synchronization (db.json) and CMS image uploads in Vercel production.
# Obtain this from your Vercel Dashboard -> Storage -> Blob store -> Settings.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token_here

# 3. Resend Email Delivery API
# Required to email password reset links to the admin's contact email.
# Create an account at https://resend.com and obtain an API key.
RESEND_API_KEY=re_your_resend_api_key_here

# 4. Local Development Server Config (Optional)
PORT=3000
NODE_ENV=development
